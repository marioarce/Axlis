<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>

    <!-- NuGet Package Metadata -->
    <PackageId>Axlis</PackageId>
    <PackageVersion>$(AxlisVersion)</PackageVersion>
    <Title>Axlis</Title>
    <Description>Axlis — the Sitecore Headless GraphQL ORM for .NET 8. Includes SitecoreFacade, IItemLazyLoader, SitecoreItemCacheManager, and DI registration extensions (AddAxlis). Integrates with PowerCSharp Cache for stampede-safe item caching.</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageTags>csharp;dotnet;sitecore;headless;graphql;orm;axlis;cache;di</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="8.0.0" />
    <PackageReference Include="PowerCSharp.Feature.Cache.Abstractions" Version="1.3.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Axlis.GraphQL\Axlis.GraphQL.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
